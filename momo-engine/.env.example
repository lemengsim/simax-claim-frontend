# ============================================================
# SIMAX eSIM 自動發貨引擎 — 環境變數設定範本
# 複製為 .env 並填入真實值（.env 請勿上傳 Git）
# ============================================================

# ── MOMO SCM API 帳號 ──────────────────────────────────────
MOMO_ENTP_CODE=001005          # 廠商編號 (6碼)
MOMO_ENTP_ID=12345678          # 統一編號 (8碼)
MOMO_ENTP_PWD=your_scm_password # SCM 主帳號密碼（同時作為 AES 解密金鑰）
MOMO_OTP_BACK_NO=123           # momoOTP 序號後 3 碼（SCM C1209 查詢）

# ── Supabase ───────────────────────────────────────────────
SUPABASE_URL=https://ivyczzhzusqjkqmfnwlw.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...  # service_role key

# ── Firebase Realtime Database（產品字典） ─────────────────
FIREBASE_DB_URL=https://esim-system-default-rtdb.asia-southeast1.firebasedatabase.app
FIREBASE_DB_SECRET=5ogfZra90hd8bq6rYCoS1oHHV2gdza5UzmZ8so8b

# ── DJB (DJB Telecom) API ──────────────────────────────────
DJB_BASE_URL=https://api.djbsim.com
DJB_API_IV=your_djb_api_iv
DJB_SOURCE_NO=your_djb_source_number

# ── 世界移動 (FastMove/WorldMobile) API ────────────────────
WM_BASE_URL=https://fmshippingsys.fastmove.com.tw
WM_MERCHANT_ID=your_merchant_id
WM_DEPT_ID=your_dept_id
WM_EMAIL=your_order_email@example.com
WM_TOKEN=your_sha1_token
